{
  "name": "@cinatra-ai/company-discovery-agent",
  "version": "0.1.1",
  "license": "Apache-2.0",
  "description": "Stateless leaf agent that takes a company name and/or domain and returns a normalized accountId through the crm_* facade, optionally enriched with an Apollo organization id. Dedups via crm_account_search on websiteHost.",
  "type": "module",
  "files": [
    "cinatra",
    "skills"
  ],
  "cinatra": {
    "apiVersion": "cinatra.ai/v1",
    "kind": "agent",
    "displayName": "Company Discovery Agent",
    "dependencies": [
      {
        "packageName": "@cinatra-ai/apollo-connector",
        "edgeType": "runtime",
        "versionConstraint": {
          "kind": "semver-range",
          "range": "^0.1.3"
        },
        "requirement": "optional",
        "kind": "connector"
      }
    ],
    "consumes": [
      {
        "primitive": "apollo_administration_get",
        "requirement": "optional"
      }
    ],
    "packageType": "agent",
    "manifestVersion": 1,
    "sourceTemplateId": "company-discovery-agent-flow",
    "sourceVersionId": "edc8fc0f-6aef-4795-941b-cc02e88e18e8",
    "sourceVersionNumber": 1,
    "riskLevel": "low",
    "hasApprovalGates": false,
    "toolAccess": [],
    "ownerOrgId": null
  }
}
